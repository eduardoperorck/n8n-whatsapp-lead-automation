# ─────────────────────────────────────────────────────────────────────────────
# ARQUIVO DE CONFIGURAÇÃO — WhatsApp Lead Automation
#
# INSTRUÇÕES:
#   1. Faça uma cópia deste arquivo e renomeie para: .env
#   2. Preencha cada campo com as suas informações
#   3. NUNCA envie o arquivo .env para o GitHub
#
# DICA: Se preferir não editar manualmente, use o assistente interativo:
#   bash scripts/configurar.sh
# ─────────────────────────────────────────────────────────────────────────────


# ── n8n — Plataforma de Automação ─────────────────────────────────────────────
# Onde sua automação está rodando.
# Se usar n8n Cloud: https://seu-nome.app.n8n.cloud
# Se usar localmente: http://localhost:5678
N8N_API_URL=http://localhost:5678

# Chave de acesso ao n8n. Encontre em: n8n > Settings > API > Create an API key
N8N_API_KEY=sua_chave_api_do_n8n


# ── WhatsApp Business API ──────────────────────────────────────────────────────
# URL base da API da Meta (não precisa alterar)
WHATSAPP_API_URL=https://graph.facebook.com/v18.0

# ID do número de telefone. Encontre em: developers.facebook.com > Seu App > WhatsApp > API Setup
# Exemplo: 1234567890123456
WHATSAPP_PHONE_NUMBER_ID=seu_phone_number_id

# Token de acesso do WhatsApp. Encontre na mesma página acima.
# ATENÇÃO: O token temporário expira em 24h. Para produção, gere um token permanente.
# Veja como: docs/faq.md#token-permanente
WHATSAPP_ACCESS_TOKEN=seu_whatsapp_access_token

# Token de verificação do webhook — você cria esse valor.
# Pode ser qualquer texto sem espaços (ex: minha-empresa-token-2024).
# Você vai usar esse mesmo valor na configuração do Webhook no painel Meta.
WHATSAPP_VERIFY_TOKEN=seu_token_de_verificacao


# ── Google Sheets — Planilha dos Leads ────────────────────────────────────────
# ID da sua planilha. Encontre na URL do Google Sheets:
# https://docs.google.com/spreadsheets/d/[ID_AQUI]/edit
GOOGLE_SHEETS_SPREADSHEET_ID=seu_spreadsheet_id

# Nome da aba onde os leads vão ser salvos (padrão: Leads)
GOOGLE_SHEETS_SHEET_NAME=Leads

# Caminho para o arquivo JSON da Service Account do Google.
# Veja como criar: docs/guia-passo-a-passo.md#etapa-3
# NUNCA envie este arquivo para o GitHub.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json


# ── Notificação do Agente ──────────────────────────────────────────────────────
# URL que receberá um aviso quando um lead for qualificado.
# Pode ser um webhook do Slack, Discord, ou qualquer URL que aceite POST.
# Deixe como está se ainda não tiver configurado — o sistema funciona sem isso.
AGENT_NOTIFICATION_URL=https://hooks.slack.com/services/SEU/WEBHOOK/AQUI


# ── Dados da Empresa ───────────────────────────────────────────────────────────
# Nome da empresa que aparece nas mensagens do bot
COMPANY_NAME=Minha Empresa

# Mensagem de boas-vindas que o bot envia quando alguém manda o primeiro "Oi"
WELCOME_MESSAGE=Olá! Bem-vindo(a) à Minha Empresa. Como posso ajudar?

# Lista de serviços que o bot apresenta (separe por vírgula, sem espaços extras)
SERVICES=Consultoria,Suporte,Treinamento
