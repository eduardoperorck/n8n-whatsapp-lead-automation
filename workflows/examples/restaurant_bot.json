        "specifyBody": "json",
        "jsonBody": "={\n  \"messaging_product\": \"whatsapp\",\n  \"to\": \"{{$json[\\\"from\\\"]}}\",\n  \"type\": \"text\",\n  \"text\": {\n    \"body\": \"Desculpe, no momento só consigo processar mensagens de texto. Por favor, envie sua dúvida em texto. 😊\"\n  }\n}",
        "options": {
