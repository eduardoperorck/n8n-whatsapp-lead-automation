    {
      "parameters": {
        "jsCode": "// ─────────────────────────────────────────────────────────\n// INTENT ROUTER — Determina a intenção baseada no estado da sessão\n// Estado persistido via campo sessionState no payload\n// ─────────────────────────────────────────────────────────\n\nconst data = $input.first().json;\nconst SESSION_TIMEOUT_MS = 30 * 60 * 1000; // 30 minutos\n\n// Estado da sessão: em produção, persistir em banco de dados/Redis\n// Aqui usamos o campo sessionData passado pelo fluxo para simplicidade do template\nconst sessionData = data.sessionData || {};\nconst lastActivity = sessionData.lastActivity || 0;\nconst now = Date.now();\n\n// Verifica timeout de sessão\nconst sessionExpired = (now - lastActivity) > SESSION_TIMEOUT_MS;\n\nlet intent;\n\nif (data.isGreeting || !sessionData.state || sessionExpired) {\n  intent = 'greeting';\n  sessionData.state = 'GREETING_SENT';\n  sessionData.answers = {};\n} else if (sessionData.state === 'COMPLETE') {\n  intent = 'complete';\n} else if (['Q1','Q2','Q3','Q4','Q5','GREETING_SENT'].includes(sessionData.state)) {\n  intent = 'qualifying';\n} else {\n  intent = 'unknown';\n}\n\nsessionData.lastActivity = now;\n\nreturn [{ json: {\n  ...data,\n  intent,\n  sessionData\n}}];"
      },
