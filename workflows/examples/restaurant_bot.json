      "id": "a1b2c3d4-0003-0003-0003-000000000003",
      "name": "Verify Challenge Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        680,
        160
      ]
    },
    {
      "parameters": {
        "jsCode": "// ─────────────────────────────────────────────────────────\n// MESSAGE PARSER — Valida e extrai dados do payload WhatsApp\n// Resiliência: rejeita payloads grandes, tipos inválidos, JSON malformado\n// ─────────────────────────────────────────────────────────\n\nconst MAX_PAYLOAD_BYTES = 65536; // 64KB\nconst SUPPORTED_TYPES = ['text'];\nconst GREETING_WORDS = [\n  'oi', 'olá', 'ola', 'hello', 'hi',\n  'bom dia', 'boa tarde', 'boa noite',\n  'início', 'inicio', 'começar', 'comecar',\n  'start', 'menu'\n];\n\nconst body = $input.first().json;\n\n// Guard: tamanho do payload\nconst payloadSize = JSON.stringify(body).length;\nif (payloadSize > MAX_PAYLOAD_BYTES) {\n  console.error(`[MessageParser] Payload rejeitado: ${payloadSize} bytes (máx: ${MAX_PAYLOAD_BYTES})`);\n  return [{ json: { valid: false, error: 'PAYLOAD_TOO_LARGE', size: payloadSize } }];\n}\n\n// Guard: estrutura do WhatsApp Business API\ntry {\n  const entry = body?.entry?.[0];\n  const change = entry?.changes?.[0];\n  const value = change?.value;\n  const messageObj = value?.messages?.[0];\n\n  // Ignorar silenciosamente status updates (delivered, read, etc.)\n  if (!messageObj && value?.statuses) {\n    return [{ json: { valid: false, error: 'STATUS_UPDATE', ignore: true } }];\n  }\n\n  if (!messageObj) {\n    return [{ json: { valid: false, error: 'NO_MESSAGE_IN_PAYLOAD' } }];\n  }\n\n  const msgType = messageObj.type;\n  const from = messageObj.from;\n  const timestamp = messageObj.timestamp;\n  const messageId = messageObj.id;\n  const waBusinessId = entry?.id;\n\n  // Guard: tipo de mensagem não suportado\n  if (!SUPPORTED_TYPES.includes(msgType)) {\n    return [{ json: {\n      valid: false,\n      error: 'UNSUPPORTED_MESSAGE_TYPE',\n      messageType: msgType,\n      from,\n      waBusinessId\n    }}];\n  }\n\n  const text = messageObj.text?.body?.trim();\n\n  // Guard: texto vazio\n  if (!text) {\n    return [{ json: { valid: false, error: 'EMPTY_TEXT', from } }];\n  }\n\n  // Detecta saudação\n  const lowerText = text.toLowerCase();\n  const isGreeting = GREETING_WORDS.some(w => lowerText.includes(w));\n\n  return [{ json: {\n    valid: true,\n    from,\n    text,\n    messageType: msgType,\n    timestamp,\n    messageId,\n    waBusinessId,\n    isGreeting\n  }}];\n\n} catch (err) {\n  console.error('[MessageParser] Erro ao parsear payload:', err.message);\n  return [{ json: { valid: false, error: 'PARSE_ERROR', message: err.message } }];\n}"
      },
