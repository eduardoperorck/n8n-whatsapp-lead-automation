      "id": "a1b2c3d4-0009-0009-0009-000000000009",
      "name": "Send Welcome Message",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1560,
        360
      ]
    },
    {
      "parameters": {
        "jsCode": "// ─────────────────────────────────────────────────────────\n// LEAD QUALIFICATION — Máquina de estados de perguntas\n// Registra resposta anterior e determina próxima pergunta\n// ─────────────────────────────────────────────────────────\n\nconst QUESTIONS = [\n  { key: 'name',           state: 'Q1', question: 'Qual é o seu *nome completo*?' },\n  { key: 'contact_phone',  state: 'Q2', question: 'Qual o melhor *número para contato*? (pode ser este mesmo)' },\n  { key: 'service',        state: 'Q3', question: 'Qual serviço você tem interesse?\\nOpções: Reserva de Mesa,Delivery,Buffet para Eventos,Menu Executivo,Cardápio Vegano' },\n  { key: 'budget',         state: 'Q4', question: 'Qual seu *orçamento aproximado* para este serviço?' },\n  { key: 'timeline',       state: 'Q5', question: 'Quando você gostaria de *começar*?' }\n];\n\nconst data = $input.first().json;\nconst sessionData = data.sessionData || {};\nconst answers = sessionData.answers || {};\nconst currentState = sessionData.state || 'GREETING_SENT';\n\n// Encontra a pergunta que corresponde ao estado atual\nconst currentQuestionIndex = QUESTIONS.findIndex(q => q.state === currentState);\nconst previousQuestionIndex = currentQuestionIndex - 1;\n\n// Salva a resposta da pergunta anterior (se existir)\nif (previousQuestionIndex >= 0 && data.text) {\n  const prevQ = QUESTIONS[previousQuestionIndex];\n  answers[prevQ.key] = data.text;\n}\n\n// Se estava em GREETING_SENT, começa do zero\nif (currentState === 'GREETING_SENT' && data.text) {\n  answers['name'] = data.text;\n}\n\n// Determina próxima pergunta\nconst answeredCount = Object.keys(answers).length;\nconst nextQuestion = QUESTIONS[answeredCount];\n\nlet nextState;\nlet qualificationComplete = false;\nlet leadData = null;\n\nif (!nextQuestion) {\n  // Todas as perguntas respondidas\n  nextState = 'COMPLETE';\n  qualificationComplete = true;\n  leadData = {\n    company: 'Restaurante Sabor & Arte',\n    whatsapp: data.from,\n    timestamp: new Date().toISOString(),\n    status: 'novo',\n    ...answers\n  };\n} else {\n  nextState = nextQuestion.state;\n}\n\nsessionData.state = nextState;\nsessionData.answers = answers;\nsessionData.lastActivity = Date.now();\n\nreturn [{ json: {\n  ...data,\n  sessionData,\n  nextQuestion: nextQuestion?.question || null,\n  qualificationComplete,\n  leadData,\n  answers\n}}];"
      },
