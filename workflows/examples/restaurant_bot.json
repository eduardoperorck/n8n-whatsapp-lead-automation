        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"messaging_product\": \"whatsapp\",\n  \"to\": \"{{$json[\\\"from\\\"]}}\",\n  \"type\": \"text\",\n  \"text\": {\n    \"body\": \"Olá! Bem-vindo ao Restaurante Sabor & Arte. Queremos que sua experiência seja incrível! 🍽️\\n\\nNossos serviços:\\nReserva de Mesa,Delivery,Buffet para Eventos,Menu Executivo,Cardápio Vegano\\n\\nPara começar, me diga: qual é o seu *nome completo*?\"\n  }\n}",
